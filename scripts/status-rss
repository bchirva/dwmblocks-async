#!/usr/bin/env sh

if ! command -v newsboat >/dev/null; then 
    printf '\0'
    exit 0
fi

case "$BLOCK_BUTTON" in 
    1) $TERMINAL -e newsboat ;;
esac

news_count=$(newsboat -x print-unread | cut -d ' ' -f 1)

if [ "$news_count" -ne 0 ]; then 
    _dwm-block-2d " $news_count"
else 
    printf '\0'
fi

